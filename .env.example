NODE_ENV=development
PORT=3333

# Configurações de Conexão com o Banco de Dados (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DIALECT=mysql
DB_USERNAME=seu_usuario_do_banco
DB_PASSWORD=sua_senha_do_banco
DB_DATABASE=patrimonio_ti

# Backups/Configurações Alternativas do Banco
DB_USER=seu_usuario_do_banco
DB_PASS=sua_senha_do_banco
DB_NAME=patrimonio_ti

# Segurança e Criptografia
JWT_SECRET=sua_chave_secreta_jwt_longa_e_segura
# Deve conter exatamente 32 caracteres para a criptografia AES funcionar corretamente
CRYPTO_SECRET=sua_chave_de_criptografia_de_32_caracteres_ex_12345678901234567890123456789012

# Configurações de Inicialização (Seeders)
ADMIN_DEFAULT_PASSWORD=123456